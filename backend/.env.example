# ============================================================================
# MILLION PIXEL GRID - ENVIRONMENT CONFIGURATION
# 
# This file contains all configuration needed for the application.
# Copy this to .env and fill in your actual values.
# 
# IMPORTANT: Never commit .env to git (add to .gitignore)
# ============================================================================

# ========== SERVER CONFIGURATION ==========
# Port the backend server runs on
PORT=5000

# Node.js environment (development, production, test)
NODE_ENV=development

# ========== DATABASE CONFIGURATION ==========
# Path to SQLite database file (created automatically)
DB_PATH=./database/million-pixel.db

# ========== JWT CONFIGURATION ==========
# Secret key for signing JWT tokens
# Change this to a long random string in production!
# Example: openssl rand -base64 32
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_12345

# How long JWT tokens are valid for
# Examples: 7d, 24h, 1w
JWT_EXPIRY=7d

# ========== STRIPE CONFIGURATION ==========
# Get these from your Stripe Dashboard (https://dashboard.stripe.com)

# Your secret API key (starts with sk_test_)
# IMPORTANT: Keep this secret! Never share or commit!
STRIPE_SECRET_KEY=sk_test_YOUR_KEY_HERE

# Your publishable key (starts with pk_test_)
# This can be shared publicly (used in frontend)
STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_KEY_HERE

# Webhook signing secret (from Webhooks section)
# Used to verify webhooks are really from Stripe
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET_HERE

# ========== APPLICATION URLS ==========
# Frontend URL (where users access the app)
FRONTEND_URL=http://localhost:3000

# Backend URL (for API calls)
BACKEND_URL=http://localhost:5000

# Production example:
# FRONTEND_URL=https://myapp.com
# BACKEND_URL=https://api.myapp.com

# ========== OPTIONAL: STRIPE PRODUCT ==========
# If using WooCommerce, product ID
# Leave blank if not using WooCommerce
STRIPE_PRODUCT_ID=prod_your_product_id_here

# ========== LOGGING ==========
# Set to true to see detailed logs
DEBUG=false

# ============================================================================
# INSTRUCTIONS FOR GETTING STRIPE KEYS:
# 
# 1. Go to https://stripe.com/docs/keys
# 2. Sign in to your Stripe dashboard
# 3. Find API keys section
# 4. Copy "Secret Key" to STRIPE_SECRET_KEY
# 5. Copy "Publishable Key" to STRIPE_PUBLISHABLE_KEY
# 
# FOR WEBHOOK SECRET:
# 1. In Stripe Dashboard, go to Developers > Webhooks
# 2. Click "Add endpoint"
# 3. URL: http://localhost:5000/api/webhook/stripe
# 4. Events: check "checkout.session.completed"
# 5. Copy signing secret to STRIPE_WEBHOOK_SECRET
# ============================================================================
